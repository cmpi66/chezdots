#!/usr/bin/env bash
BROWSER="qutebrowser"
BROWSER2="stupid-web"
SESSION="initial"

check_internet() {
  while ! ip route | grep -q "^default"; do
    sleep 0.5
  done
  while ! ping -c1 -W1 1.1.1.1 >/dev/null 2>&1; do
    sleep 0.5
  done
}

launch_browsers() {
  niri msg windows | grep -iq org.qute || $BROWSER &
  while ! niri msg windows | grep -iq org.qute; do
    sleep 0.3
  done

  niri msg action toggle-column-tabbed-display

  niri msg windows | grep -iq stupid-web || $BROWSER2 &
  while ! niri msg windows | grep -iq stupid-web; do
    sleep 0.3
  done

  niri msg action consume-or-expel-window-left
}

# --- main flow ---
check_internet

# skip everything if already running
if niri msg windows | grep -iq tmux-initial; then
  exit 0
fi

# launch tmux + kitty
if tmux has-session -t "$SESSION" 2>/dev/null; then
  kitty --title tmux-initial --class tmux-session -e tmux attach-session -t "$SESSION" &
else
  tmux new-session -s "$SESSION" -n initial -d
  kitty --title tmux-initial --class tmux-session -e tmux attach-session -t "$SESSION" &
fi

# needed to keep term on workspace 1
while ! niri msg windows | grep -iq tmux-initial; do
  sleep 0.3
done

niri msg action focus-workspace-down
launch_browsers
